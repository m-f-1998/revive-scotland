{
  "name": "revive-scotland-server",
  "version": "1.0.0",
  "description": "Server for Revive Scotland",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "prestart": "npm i",
    "start": "node --env-file=.env --watch ./ index.js",
    "dev": "npm run prestart && npx --yes nodemon -e ts --exec \"tsc && node ./dist/index.js\"",
    "lint": "npx --yes eslint",
    "lint:fix": "npx --yes eslint --fix",
    "tsc-verify": "npx --yes tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1037.0",
    "@aws-sdk/s3-request-presigner": "^3.1037.0",
    "@fastify/compress": "^8.3.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.4",
    "@google-analytics/data": "^5.2.1",
    "body-parser": "^2.2.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "firebase-admin": "^13.8.0",
    "google-auth-library": "^10.6.2",
    "mime": "^4.1.0",
    "nodemailer": "^8.0.6",
    "pino-pretty": "^13.1.3",
    "sanitize-html": "^2.17.3",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/mime": "^3.0.4",
    "@types/nodemailer": "^8.0.0",
    "@types/sanitize-html": "^2.16.1",
    "eslint-plugin-import": "^2.32.0",
    "typescript-eslint": "^8.59.0"
  },
  "volta": {
    "node": "24.15.0"
  }
}
